[Unit]
Description=ops-agent Telegram ChatOps
After=network-online.target ops-api.service
Wants=network-online.target

[Service]
Type=simple
User=ops-agent
Group=ops-agent
WorkingDirectory=/opt/ops-agent
EnvironmentFile=/etc/ops-agent/ops-agent.env
ExecStart=/usr/local/bin/ops-telegram --api-base http://127.0.0.1:8090 --api-token ${OPS_API_TOKEN} --env-file /etc/ops-agent/environments.yaml --bot-token ${OPS_TG_BOT_TOKEN} --chat-id ${OPS_TG_CHAT_ID} --chatops-config /etc/ops-agent/chatops.yaml --audit /var/lib/ops-agent/telegram.jsonl --offset-file /var/lib/ops-agent/telegram-offset.txt --llm-state-file /var/lib/ops-agent/telegram-openai-response.txt --llm-confirm-file /var/lib/ops-agent/telegram-openai-confirmation.json
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/ops-agent

[Install]
WantedBy=multi-user.target
